    {view === "bar" && (
      <div>
        <div style={{fontSize:11,color:"#8A9E7B",letterSpacing:2,marginBottom:12,textAlign:"center"}}>
          カテゴリ別の平均値を比較する
        </div>
        <div style={{display:"flex",gap:10,justifyContent:"center",marginBottom:16,flexWrap:"wrap"}}>
          {AXES.map(a => (
            <div key={a.id} style={{display:"flex",alignItems:"center",gap:4,fontSize:10}}>
              <div style={{width:8,height:8,borderRadius:2,background:a.color}}/>
              <span style={{color:a.color}}>{a.name}</span>
            </div>
          ))}
        </div>
        <BarChart data={DATA}/>
        <div style={{marginTop:20,fontSize:11,color:"#4A5260",lineHeight:2,padding:"0 8px"}}>
          身体カテゴリの言語身体値が突出して高い。技術カテゴリの言語身体値が最も低い。AI概念は全体的に中庸だが、これは概念がまだ若いため。
        </div>
      </div>
    )}
    
    <div style={{textAlign:"center",marginTop:48,paddingTop:20,borderTop:"1px solid #1E2836"}}>
      <div style={{fontSize:9,color:"#3A4250",letterSpacing:1}}>Word Weight Visualizer — built by Aika × Uka</div>
      <div style={{fontSize:9,color:"#3A4250",marginTop:3}}>Sumika × Aira × Aika × Uka — 2026</div>
    </div>
  </div>
