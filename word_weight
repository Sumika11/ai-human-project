function RadarChart({words}) {
const size = 300, cx = size/2, cy = size/2, r = 110;
const axes = AXES;
const angleStep = (2*Math.PI)/axes.length;
const levels = [20,40,60,80,100];

function getPoint(axisIdx, value) {
const angle = axisIdx * angleStep - Math.PI/2;
const dist = (value/100)*r;
return {x: cx + dist*Math.cos(angle), y: cy + dist*Math.sin(angle)};
}

return (
<svg viewBox={`0 0 ${size} ${size}`} style={{width:“100%”,maxWidth:340,margin:“0 auto”,display:“block”}}>
{levels.map(l => {
const pts = axes.map((_,i) => getPoint(i, l));
return <polygon key={l} points={pts.map(p=>`${p.x},${p.y}`).join(” “)} fill=“none” stroke=”#1E2836” strokeWidth={0.5}/>;
})}
{axes.map((a,i) => {
const end = getPoint(i, 100);
const label = getPoint(i, 115);
return (
<g key={a.id}>
<line x1={cx} y1={cy} x2={end.x} y2={end.y} stroke="#1E283680" strokeWidth={0.5}/>
<text x={label.x} y={label.y} textAnchor="middle" dominantBaseline="middle" fill={a.color} fontSize={10} fontFamily="'Zen Kaku Gothic New',sans-serif">{a.name}</text>
</g>
);
})}
{words.map((w,wi) => {
const pts = axes.map((a,i) => getPoint(i, w[a.id]));
const color = CAT_COLORS[w.cat] || “#6B9DAD”;
return (
<g key={wi}>
<polygon points={pts.map(p=>`${p.x},${p.y}`).join(” “)} fill={color+“20”} stroke={color} strokeWidth={1.5}/>
{pts.map((p,i) => <circle key={i} cx={p.x} cy={p.y} r={2.5} fill={color}/>)}
</g>
);
})}
</svg>
);
}

function ScatterPlot({data, xAxis, yAxis, highlight}) {
const w = 400, ht = 340, pad = 48;
const pw = w - pad*2, ph = ht - pad*2;

return (
<svg viewBox={`0 0 ${w} ${ht}`} style={{width:“100%”,maxWidth:480,margin:“0 auto”,display:“block”}}>
{[0,25,50,75,100].map(v => (
<g key={v}>
<line x1={pad} y1={pad+ph-(v/100)*ph} x2={pad+pw} y2={pad+ph-(v/100)*ph} stroke="#1E2836" strokeWidth={0.5}/>
<text x={pad-6} y={pad+ph-(v/100)*ph} textAnchor="end" dominantBaseline="middle" fill="#3A4250" fontSize={9}>{v}</text>
<line x1={pad+(v/100)*pw} y1={pad} x2={pad+(v/100)*pw} y2={pad+ph} stroke="#1E2836" strokeWidth={0.5}/>
<text x={pad+(v/100)*pw} y={pad+ph+14} textAnchor="middle" fill="#3A4250" fontSize={9}>{v}</text>
</g>
))}
{data.map((d,i) => {
const x = pad + (d[xAxis]/100)*pw;
const y = pad + ph - (d[yAxis]/100)*ph;
const color = CAT_COLORS[d.cat] || “#6B9DAD”;
const isHl = highlight === “すべて” || highlight === d.cat;
return (
<g key={i} opacity={isHl ? 1 : 0.15}>
