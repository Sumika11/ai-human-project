{isHl && <text x={x+6} y={y-4} fill={color} fontSize={8} fontFamily="'Zen Kaku Gothic New',sans-serif">{d.word}</text>}
</g>
);
})}
<text x={pad+pw/2} y={ht-4} textAnchor="middle" fill="#6B7580" fontSize={10} fontFamily="'Zen Kaku Gothic New',sans-serif">
{AXES.find(a=>a.id===xAxis)?.name}
</text>
<text x={10} y={pad+ph/2} textAnchor=“middle” dominantBaseline=“middle” fill=”#6B7580” fontSize={10} fontFamily=”‘Zen Kaku Gothic New’,sans-serif” transform={`rotate(-90,10,${pad+ph/2})`}>
{AXES.find(a=>a.id===yAxis)?.name}
</text>
</svg>
);
}

function BarChart({data}) {
const cats = […new Set(data.map(d=>d.cat))];
const catAvg = cats.map(c => {
const items = data.filter(d=>d.cat===c);
return {
cat: c,
teii: Math.round(items.reduce((s,d)=>s+d.teii,0)/items.length),
shokuhatsu: Math.round(items.reduce((s,d)=>s+d.shokuhatsu,0)/items.length),
gengo: Math.round(items.reduce((s,d)=>s+d.gengo,0)/items.length),
keiro: Math.round(items.reduce((s,d)=>s+d.keiro,0)/items.length),
};
});

const bw = 12, gap = 3, groupGap = 20;
const groupW = bw*4 + gap*3;
const totalW = catAvg.length*(groupW+groupGap) + 60;
const ht = 280, pad = 40, ph = ht - pad*2;

return (
<div style={{overflowX:“auto”,WebkitOverflowScrolling:“touch”}}>
<svg viewBox={`0 0 ${totalW} ${ht}`} style={{width:totalW,minWidth:totalW,height:ht,display:“block”}}>
{[0,25,50,75,100].map(v => (
<g key={v}>
<line x1={pad} y1={pad+ph-(v/100)*ph} x2={totalW-10} y2={pad+ph-(v/100)*ph} stroke="#1E2836" strokeWidth={0.5}/>
<text x={pad-4} y={pad+ph-(v/100)*ph} textAnchor="end" dominantBaseline="middle" fill="#3A4250" fontSize={8}>{v}</text>
</g>
))}
{catAvg.map((c,ci) => {
const gx = pad + 10 + ci*(groupW+groupGap);
return (
<g key={ci}>
{AXES.map((a,ai) => {
const val = c[a.id];
const bh = (val/100)*ph;
const x = gx + ai*(bw+gap);
return (
<g key={a.id}>
<rect x={x} y={pad+ph-bh} width={bw} height={bh} fill={a.color} rx={2} opacity={0.8}/>
<text x={x+bw/2} y={pad+ph-bh-4} textAnchor="middle" fill={a.color} fontSize={7}>{val}</text>
</g>
);
})}
<text x={gx+groupW/2} y={pad+ph+14} textAnchor="middle" fill={CAT_COLORS[c.cat]} fontSize={9} fontFamily="'Zen Kaku Gothic New',sans-serif">{c.cat}</text>
</g>
);
})}
</svg>
</div>
);
}

