          <span style={{fontSize:10,color:"#4A5260"}}>X軸:</span>
          {AXES.map(a => (
            <button key={a.id} onClick={()=>setScatterX(a.id)} style={{
              padding:"4px 10px",borderRadius:16,fontSize:10,cursor:"pointer",
              background:scatterX===a.id?"#1A2233":"transparent",
              border:`1px solid ${scatterX===a.id?a.color+"60":"#1E2836"}`,
              color:scatterX===a.id?a.color:"#4A5260"
            }}>{a.name}</button>
          ))}
        </div>
        <div style={{display:"flex",gap:8,justifyContent:"center",marginBottom:12,flexWrap:"wrap",alignItems:"center"}}>
          <span style={{fontSize:10,color:"#4A5260"}}>Y軸:</span>
          {AXES.map(a => (
            <button key={a.id} onClick={()=>setScatterY(a.id)} style={{
              padding:"4px 10px",borderRadius:16,fontSize:10,cursor:"pointer",
              background:scatterY===a.id?"#1A2233":"transparent",
              border:`1px solid ${scatterY===a.id?a.color+"60":"#1E2836"}`,
              color:scatterY===a.id?a.color:"#4A5260"
            }}>{a.name}</button>
          ))}
        </div>
        <div style={{display:"flex",gap:6,justifyContent:"center",marginBottom:16,flexWrap:"wrap"}}>
          {CATS.map(c => (
            <button key={c} onClick={()=>setScatterCat(c)} style={{
              padding:"3px 10px",borderRadius:16,fontSize:9,cursor:"pointer",
              background:scatterCat===c?"#1A2233":"transparent",
              border:`1px solid ${scatterCat===c?(CAT_COLORS[c]||"#2A3648")+"60":"#1E2836"}`,
              color:scatterCat===c?(CAT_COLORS[c]||"#C8CDD4"):"#3A4250"
            }}>{c}</button>
          ))}
        </div>
        <ScatterPlot data={DATA} xAxis={scatterX} yAxis={scatterY} highlight={scatterCat}/>
      </div>
