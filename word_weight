            <div style={{marginTop:20}}>
              {radarData.map((w,wi) => (
                <div key={wi} style={{padding:"12px 16px",background:"#141920",borderRadius:8,border:"1px solid #1E283640",marginBottom:8}}>
                  <div style={{fontSize:16,fontWeight:300,color:CAT_COLORS[w.cat],marginBottom:6}}>{w.word}</div>
