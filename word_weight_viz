pts.forEach(function(p){var ci=document.createElementNS(ns,“circle”);ci.setAttribute(“cx”,p.x);ci.setAttribute(“cy”,p.y);ci.setAttribute(“r”,“2.5”);ci.setAttribute(“fill”,col);svg.appendChild(ci);});
});
ct.appendChild(svg);
var lg=document.createElement(“div”);lg.className=“legend-row”;lg.style.marginTop=“12px”;
words.forEach(function(w){
var col=CC[w.cat];
var it=document.createElement(“div”);it.className=“legend-item”;
var dt=document.createElement(“div”);dt.className=“legend-dot”;dt.style.background=col;it.appendChild(dt);
var sp=document.createElement(“span”);sp.style.color=col;sp.textContent=w.word;it.appendChild(sp);
var rm=document.createElement(“span”);rm.style.cssText=“color:#ccc;cursor:pointer;font-size:9px;margin-left:2px”;rm.textContent=“✕”;
rm.onclick=function(){radarWords=radarWords.filter(function(x){return x!==w.word});render();};it.appendChild(rm);
lg.appendChild(it);
});
ct.appendChild(lg);
words.forEach(function(w){
var cd=document.createElement(“div”);cd.className=“card”;
var nm=document.createElement(“div”);nm.style.cssText=“font-size:16px;font-weight:300;margin-bottom:6px;color:”+(CC[w.cat]);nm.textContent=w.word;cd.appendChild(nm);
var row=document.createElement(“div”);row.style.cssText=“display:flex;gap:16px;flex-wrap:wrap;font-size:11px”;
AXES.forEach(function(a){var s=document.createElement(“span”);s.style.color=”#888”;s.innerHTML=”<span style='color:"+a.c+"'>”+a.name+”</span> “+w[a.id];row.appendChild(s);});
cd.appendChild(row);ct.appendChild(cd);
});
}
function addRW(){var inp=document.getElementById(“radar-input”);var w=inp.value.trim();if(w&&DATA.find(function(d){return d.word===w})&&radarWords.indexOf(w)<0){radarWords.push(w);if(radarWords.length>4)radarWords.shift();}inp.value=””;render();}

function renderScatter(ct){
var lbl=document.createElement(“div”);lbl.className=“section-label”;lbl.textContent=“108語を2軸で配置する”;ct.appendChild(lbl);
var xr=document.createElement(“div”);xr.className=“ctrl-row”;
xr.appendChild(mkLbl(“X軸:”));
AXES.forEach(function(a){xr.appendChild(mkPill(a.name,scatterX===a.id,scatterX===a.id?a.c:null,function(){scatterX=a.id;render();}));});
ct.appendChild(xr);
var yr=document.createElement(“div”);yr.className=“ctrl-row”;
yr.appendChild(mkLbl(“Y軸:”));
AXES.forEach(function(a){yr.appendChild(mkPill(a.name,scatterY===a.id,scatterY===a.id?a.c:null,function(){scatterY=a.id;render();}));});
ct.appendChild(yr);
var fr=document.createElement(“div”);fr.className=“ctrl-row”;fr.style.marginBottom=“16px”;
CATS.forEach(function(c){
var col=scatterCat===c?(CC[c]||”#555”):null;
fr.appendChild(mkPillSm(c,scatterCat===c,col,function(){scatterCat=c;render();}));
});
ct.appendChild(fr);
var ns=“http://www.w3.org/2000/svg”,w=420,ht=360,pad=48,pw=w-pad*2,ph=ht-pad*2;
var svg=document.createElementNS(ns,“svg”);svg.setAttribute(“viewBox”,“0 0 “+w+” “+ht);svg.style.cssText=“width:100%;max-width:500px;margin:0 auto;display:block”;
[0,25,50,75,100].forEach(function(v){
var ln1=document.createElementNS(ns,“line”);ln1.setAttribute(“x1”,pad);ln1.setAttribute(“y1”,pad+ph-(v/100)*ph);ln1.setAttribute(“x2”,pad+pw);ln1.setAttribute(“y2”,pad+ph-(v/100)*ph);ln1.setAttribute(“stroke”,”#E8E0D8”);ln1.setAttribute(“stroke-width”,“0.5”);svg.appendChild(ln1);
var t1=document.createElementNS(ns,“text”);t1.setAttribute(“x”,pad-6);t1.setAttribute(“y”,pad+ph-(v/100)*ph);t1.setAttribute(“text-anchor”,“end”);t1.setAttribute(“dominant-baseline”,“middle”);t1.setAttribute(“fill”,”#bbb”);t1.setAttribute(“font-size”,“9”);t1.textContent=v;svg.appendChild(t1);
var ln2=document.createElementNS(ns,“line”);ln2.setAttribute(“x1”,pad+(v/100)*pw);ln2.setAttribute(“y1”,pad);ln2.setAttribute(“x2”,pad+(v/100)*pw);ln2.setAttribute(“y2”,pad+ph);ln2.setAttribute(“stroke”,”#E8E0D8”);ln2.setAttribute(“stroke-width”,“0.5”);svg.appendChild(ln2);
var t2=document.createElementNS(ns,“text”);t2.setAttribute(“x”,pad+(v/100)*pw);t2.setAttribute(“y”,pad+ph+14);t2.setAttribute(“text-anchor”,“middle”);t2.setAttribute(“fill”,”#bbb”);t2.setAttribute(“font-size”,“9”);t2.textContent=v;svg.appendChild(t2);
});
DATA.forEach(function(d){
var x=pad+(d[scatterX]/100)*pw,y=pad+ph-(d[scatterY]/100)*ph;
var col=CC[d.cat]||”#5A8FA0”;
var hl=scatterCat===“すべて”||scatterCat===d.cat;
var g=document.createElementNS(ns,“g”);g.setAttribute(“opacity”,hl?“1”:“0.12”);
var ci=document.createElementNS(ns,“circle”);ci.setAttribute(“cx”,x);ci.setAttribute(“cy”,y);ci.setAttribute(“r”,“4.5”);ci.setAttribute(“fill”,col);ci.setAttribute(“opacity”,“0.65”);g.appendChild(ci);
if(hl){var tx=document.createElementNS(ns,“text”);tx.setAttribute(“x”,x+7);tx.setAttribute(“y”,y-5);tx.setAttribute(“fill”,col);tx.setAttribute(“font-size”,“8”);tx.setAttribute(“font-family”,”‘Zen Kaku Gothic New’,sans-serif”);tx.textContent=d.word;g.appendChild(tx);}
svg.appendChild(g);
});
var xLbl=document.createElementNS(ns,“text”);xLbl.setAttribute(“x”,pad+pw/2);xLbl.setAttribute(“y”,ht-6);xLbl.setAttribute(“text-anchor”,“middle”);xLbl.setAttribute(“fill”,”#999”);xLbl.setAttribute(“font-size”,“11”);xLbl.setAttribute(“font-family”,”‘Zen Kaku Gothic New’,sans-serif”);xLbl.textContent=AXES.find(function(a){return a.id===scatterX}).name;svg.appendChild(xLbl);
var yLbl=document.createElementNS(ns,“text”);yLbl.setAttribute(“x”,“12”);yLbl.setAttribute(“y”,pad+ph/2);yLbl.setAttribute(“text-anchor”,“middle”);yLbl.setAttribute(“dominant-baseline”,“middle”);yLbl.setAttribute(“fill”,”#999”);yLbl.setAttribute(“font-size”,“11”);yLbl.setAttribute(“font-family”,”‘Zen Kaku Gothic New’,sans-serif”);yLbl.setAttribute(“transform”,“rotate(-90,12,”+(pad+ph/2)+”)”);yLbl.textContent=AXES.find(function(a){return a.id===scatterY}).name;svg.appendChild(yLbl);
ct.appendChild(svg);
}

function renderBar(ct){
var lbl=document.createElement(“div”);lbl.className=“section-label”;lbl.textContent=“カテゴリ別の平均値を比較する”;ct.appendChild(lbl);
var lg=document.createElement(“div”);lg.className=“legend-row”;
AXES.forEach(function(a){var it=document.createElement(“div”);it.className=“legend-item”;var sq=document.createElement(“div”);sq.className=“legend-sq”;sq.style.background=a.c;it.appendChild(sq);var sp=document.createElement(“span”);sp.style.color=a.c;sp.textContent=a.name;it.appendChild(sp);lg.appendChild(it);});
ct.appendChild(lg);
var cats=[…new Set(DATA.map(function(d){return d.cat}))];
var avg=cats.map(function(c){var items=DATA.filter(function(d){return d.cat===c});return{cat:c,teii:Math.round(items.reduce(function(s,d){return s+d.teii},0)/items.length),shokuhatsu:Math.round(items.reduce(function(s,d){return s+d.shokuhatsu},0)/items.length),gengo:Math.round(items.reduce(function(s,d){return s+d.gengo},0)/items.length),keiro:Math.round(items.reduce(function(s,d){return s+d.keiro},0)/items.length)};});
var ns=“http://www.w3.org/2000/svg”,bw=12,gap=3,gg=22,gw=bw*4+gap*3,tw=avg.length*(gw+gg)+70,ht=280,pad=40,ph=ht-pad*2;
var dv=document.createElement(“div”);dv.className=“chart-wrap”;
var svg=document.createElementNS(ns,“svg”);svg.setAttribute(“viewBox”,“0 0 “+tw+” “+ht);svg.style.cssText=“width:”+tw+“px;min-width:”+tw+“px;height:”+ht+“px;display:block”;
[0,25,50,75,100].forEach(function(v){
var ln=document.createElementNS(ns,“line”);ln.setAttribute(“x1”,pad);ln.setAttribute(“y1”,pad+ph-(v/100)*ph);ln.setAttribute(“x2”,tw-10);ln.setAttribute(“y2”,pad+ph-(v/100)*ph);ln.setAttribute(“stroke”,”#E8E0D8”);ln.setAttribute(“stroke-width”,“0.5”);svg.appendChild(ln);
var tx=document.createElementNS(ns,“text”);tx.setAttribute(“x”,pad-4);tx.setAttribute(“y”,pad+ph-(v/100)*ph);tx.setAttribute(“text-anchor”,“end”);tx.setAttribute(“dominant-baseline”,“middle”);tx.setAttribute(“fill”,”#bbb”);tx.setAttribute(“font-size”,“8”);tx.textContent=v;svg.appendChild(tx);
});
avg.forEach(function(c,ci){
var gx=pad+10+ci*(gw+gg);
AXES.forEach(function(a,ai){
var val=c[a.id],bh=(val/100)*ph,x=gx+ai*(bw+gap);
var rc=document.createElementNS(ns,“rect”);rc.setAttribute(“x”,x);rc.setAttribute(“y”,pad+ph-bh);rc.setAttribute(“width”,bw);rc.setAttribute(“height”,bh);rc.setAttribute(“fill”,a.c);rc.setAttribute(“rx”,“2”);rc.setAttribute(“opacity”,“0.75”);svg.appendChild(rc);
var tx=document.createElementNS(ns,“text”);tx.setAttribute(“x”,x+bw/2);tx.setAttribute(“y”,pad+ph-bh-4);tx.setAttribute(“text-anchor”,“middle”);tx.setAttribute(“fill”,a.c);tx.setAttribute(“font-size”,“7”);tx.textContent=val;svg.appendChild(tx);
});
var cl=document.createElementNS(ns,“text”);cl.setAttribute(“x”,gx+gw/2);cl.setAttribute(“y”,pad+ph+14);cl.setAttribute(“text-anchor”,“middle”);cl.setAttribute(“fill”,CC[c.cat]);cl.setAttribute(“font-size”,“9”);cl.setAttribute(“font-family”,”‘Zen Kaku Gothic New’,sans-serif”);cl.textContent=c.cat;svg.appendChild(cl);
});
dv.appendChild(svg);ct.appendChild(dv);
var nt=document.createElement(“div”);nt.className=“note”;nt.textContent=“身体カテゴリの言語身体値が突出して高い。技術カテゴリの言語身体値が最も低い。AI概念は全体的に中庸——概念がまだ若いため。”;ct.appendChild(nt);
}

function mkLbl(t){var s=document.createElement(“span”);s.className=“ctrl-label”;s.textContent=t;return s;}
function mkPill(t,act,col,fn){var b=document.createElement(“button”);b.className=“pill”+(act?” active”:””);b.textContent=t;if(col)b.style.color=col;b.onclick=fn;return b;}
function mkPillSm(t,act,col,fn){var b=document.createElement(“button”);b.className=“pill-sm”+(act?” active”:””);b.textContent=t;if(col)b.style.color=col;b.onclick=fn;return b;}
render();
</script>

